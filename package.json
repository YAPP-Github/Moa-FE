{
  "name": "27th-web-team-3-fe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "preview": "vite preview",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "deploy": "dotenv -- bash .github/scripts/deploy.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "generate:icons": "svgr --config-file svgr.icons.config.js src/shared/assets/icons",
    "generate:logos": "svgr --config-file svgr.logos.config.js src/shared/assets/logos",
    "generate:svg": "pnpm run generate:icons && pnpm run generate:logos && pnpm run lint:fix && pnpm run format",
    "generate:api": "orval --config ./orval.config.ts && sed -i '' '1,/\\*\\//{ /\\*\\//a\\\n\\\n// TODO: 백엔드 OpenAPI 스펙 수정 후 제거 필요\\\nexport type SocialType = '\"'\"'GOOGLE'\"'\"' | '\"'\"'KAKAO'\"'\"';\\\nexport interface BaseResponse {\\\n  code: number;\\\n  isSuccess: boolean;\\\n  message: string;\\\n  result?: unknown;\\\n}\\\n\n}' src/shared/api/generated/index.ts && pnpm run lint:fix && pnpm run format"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@lukemorales/query-key-factory": "^1.3.4",
    "@tanstack/react-query": "^5.90.16",
    "axios": "^1.13.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "pretendard": "^1.3.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "react-router": "^7.11.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@storybook/addon-essentials": "^8",
    "@storybook/react": "^8",
    "@storybook/react-vite": "^8",
    "@svgr/cli": "^8.1.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.18",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "orval": "^8.2.0",
    "storybook": "^8",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
